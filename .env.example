BOT_TOKEN=ВАШ_ТОКЕН_ОТ_BOTFATHER             # Токен вашего Telegram-бота (получать у @BotFather)
ADMIN_ID=123456789                           # Ваш числовой Telegram ID (для доступа к админ-панели и Level 4/5)
DATABASE_URL=sqlite+aiosqlite:///database.db # Строка подключения (по умолчанию локальная SQLite)
WEATHER_API_KEY=ваш_ключ_openweathermap      # Ключ от API OpenWeatherMap (для команды погоды)
GIPHY_API_KEY=ваш_ключ_giphy                 # Ключ от Giphy API (для поиска GIF-анимаций)
AI_API_KEY=ваш_ключ_groqcloud                # Ключ от GroqCloud / OpenAI API (для ИИ-генераций)
OCR_API_KEY=ваш_ключ_ocr_space               # Ключ от OCR.Space (для распознавания текста с картинок)
FFMPEG_PATH=C:/ffmpeg/bin/ffmpeg.exe         # Абсолютный путь к ffmpeg (для конвертации видео в аудио)
GITHUB_REPO=https://github.com/user/repo     # Ссылка на ваш репозиторий (для отслеживания Webhooks)
WEBAPP_URL=https://ваш-адрес.ngrok-free.app  # HTTPS-ссылка туннеля Ngrok (или локальный сервер) для раздачи WebApp